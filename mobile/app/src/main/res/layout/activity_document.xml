<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".features.document.DocumentActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0F172A"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/topToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1E293B"
            app:title="Document Requests"
            app:titleTextColor="#FFFFFF" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardBackgroundColor="#1E293B"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="20dp"
                            android:text="New Request"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Full Name"
                            android:textColor="#94A3B8" />

                        <EditText
                            android:id="@+id/etDocFullName"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginBottom="16dp"
                            android:background="@drawable/input_style"
                            android:enabled="false"
                            android:paddingHorizontal="16dp"
                            android:hint="Juan Dela Cruz"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#475569"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Document Type"
                            android:textColor="#94A3B8" />

                        <Spinner
                            android:id="@+id/spinnerDocType"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginBottom="16dp"
                            android:background="@drawable/input_style"
                            android:paddingHorizontal="12dp"
                            android:popupTheme="@style/ThemeOverlay.AppCompat.Dark"
                            android:entries="@array/document_types" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Urgency Level"
                            android:textColor="#94A3B8" />

                        <Spinner
                            android:id="@+id/spinnerUrgency"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginBottom="16dp"
                            android:background="@drawable/input_style"
                            android:paddingHorizontal="12dp"
                            android:popupTheme="@style/ThemeOverlay.AppCompat.Dark"
                            android:entries="@array/urgency_levels" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Valid ID Requirement"
                            android:textColor="#94A3B8" />

                        <Spinner
                            android:id="@+id/spinnerValidId"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginBottom="16dp"
                            android:background="@drawable/input_style"
                            android:paddingHorizontal="12dp"
                            android:popupTheme="@style/ThemeOverlay.AppCompat.Dark"
                            android:entries="@array/valid_ids" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Upload ID Image"
                            android:textColor="#94A3B8" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/input_style"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="4dp">

                            <Button
                                android:id="@+id/btnChooseFile"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:backgroundTint="#334155"
                                android:text="Choose File"
                                android:textAllCaps="false"
                                android:textColor="#E2E8F0"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvFileName"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_weight="1"
                                android:text="No file chosen"
                                android:textColor="#94A3B8"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Purpose"
                            android:textColor="#94A3B8" />

                        <EditText
                            android:id="@+id/etDocPurpose"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:layout_marginBottom="24dp"
                            android:background="@drawable/input_style"
                            android:gravity="top|start"
                            android:hint="State the purpose of your request..."
                            android:inputType="textMultiLine"
                            android:padding="16dp"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#475569" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btnRemoveRequest"
                                android:layout_width="wrap_content"
                                android:layout_height="50dp"
                                android:layout_marginEnd="12dp"
                                android:backgroundTint="#334155"
                                android:text="Remove"
                                android:textAllCaps="false"
                                android:textColor="#94A3B8" />

                            <Button
                                android:id="@+id/btnSubmitRequest"
                                android:layout_width="120dp"
                                android:layout_height="50dp"
                                android:backgroundTint="#3B82F6"
                                android:text="Submit"
                                android:textAllCaps="false"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    app:cardBackgroundColor="#1E293B"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="24dp"
                            android:text="Pending Documents"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:gravity="center"
                            android:text="No pending documents found."
                            android:textColor="#64748B"
                            android:textSize="14sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    app:cardBackgroundColor="#1E293B"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="24dp"
                            android:text="Request History"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:gravity="center"
                            android:text="No pending documents found."
                            android:textColor="#64748B"
                            android:textSize="14sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#1E293B"
        app:headerLayout="@layout/nav_header"
        app:itemIconTint="#94A3B8"
        app:itemTextColor="#E2E8F0"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>