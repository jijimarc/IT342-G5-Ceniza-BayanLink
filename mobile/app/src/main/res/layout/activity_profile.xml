<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".features.profile.ProfileActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0F172A"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/topToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1E293B"
            app:title="Resident Profile"
            app:titleTextColor="#FFFFFF" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="24dp"
                    android:src="@drawable/app_logo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Personal Information"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="First Name"
                    android:textColor="#94A3B8" />

                <EditText
                    android:id="@+id/etFirstName"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/input_style"
                    android:enabled="false"
                    android:paddingHorizontal="16dp"
                    android:hint="Juan"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#475569"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Middle Name"
                    android:textColor="#94A3B8" />

                <EditText
                    android:id="@+id/etMiddleName"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/input_style"
                    android:enabled="false"
                    android:paddingHorizontal="16dp"
                    android:hint="Lee"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#475569"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Last Name"
                    android:textColor="#94A3B8" />

                <EditText
                    android:id="@+id/etLastName"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/input_style"
                    android:enabled="false"
                    android:paddingHorizontal="16dp"
                    android:hint="Dela Cruz"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#475569"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email Address"
                    android:textColor="#94A3B8" />

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/input_style"
                    android:enabled="false"
                    android:paddingHorizontal="16dp"
                    android:hint="juandelacruz@gmail.com"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#475569"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contact Number"
                    android:textColor="#94A3B8" />

                <EditText
                    android:id="@+id/etContact"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/input_style"
                    android:enabled="false"
                    android:hint="e.g., 09123456789"
                    android:paddingHorizontal="16dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#475569" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Birthdate"
                            android:textColor="#94A3B8" />

                        <EditText
                            android:id="@+id/etBirthdate"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/input_style"
                            android:enabled="false"
                            android:paddingHorizontal="16dp"
                            android:hint="01/03/2000"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#475569" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Age"
                            android:textColor="#94A3B8" />

                        <EditText
                            android:id="@+id/etAge"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/input_style"
                            android:enabled="false"
                            android:paddingHorizontal="16dp"
                            android:hint="26"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#475569"/>
                    </LinearLayout>
                </LinearLayout>


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Demographics &amp; Status"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Full Address"
                    android:textColor="#94A3B8" />

                <EditText
                    android:id="@+id/etAddress"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/input_style"
                    android:enabled="false"
                    android:paddingHorizontal="16dp"
                    android:hint="Casay, Dalaguete, Cebu"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#475569"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Civil Status"
                    android:textColor="#94A3B8" />

                <EditText
                    android:id="@+id/etCivilStatus"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/input_style"
                    android:enabled="false"
                    android:hint="Single"
                    android:paddingHorizontal="16dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#475569" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Occupation"
                    android:textColor="#94A3B8" />

                <EditText
                    android:id="@+id/etOccupation"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/input_style"
                    android:enabled="false"
                    android:paddingHorizontal="16dp"
                    android:hint="Vendor"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#475569"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Voter Status"
                    android:textColor="#94A3B8" />

                <EditText
                    android:id="@+id/etVoterStatus"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="32dp"
                    android:background="@drawable/input_style"
                    android:enabled="false"
                    android:paddingHorizontal="16dp"
                    android:hint="Registered"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#475569" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="40dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnCancelEdit"
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_marginEnd="12dp"
                        android:layout_weight="1"
                        android:backgroundTint="#334155"
                        android:text="Cancel"
                        android:textColor="#94A3B8"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <Button
                        android:id="@+id/btnEditProfile"
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_weight="1"
                        android:backgroundTint="#3B82F6"
                        android:text="Edit Profile"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#1E293B"
        app:headerLayout="@layout/nav_header"
        app:itemIconTint="#94A3B8"
        app:itemTextColor="#E2E8F0"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>