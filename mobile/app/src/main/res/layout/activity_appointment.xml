<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".features.appointment.AppointmentActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0F172A"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/topToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1E293B"
            app:title="Community Scheduling"
            app:titleTextColor="#FFFFFF" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardBackgroundColor="#1E293B"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Choose Service"
                            android:textColor="#94A3B8" />

                        <Spinner
                            android:id="@+id/spinnerService"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginBottom="16dp"
                            android:background="@drawable/input_style"
                            android:paddingHorizontal="12dp"
                            android:popupTheme="@style/ThemeOverlay.AppCompat.Dark"
                            android:entries="@array/appointment_services"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pick a Date"
                            android:textColor="#94A3B8" />

                        <TextView
                            android:id="@+id/tvDatePicker"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginBottom="24dp"
                            android:background="@drawable/input_style"
                            android:gravity="center_vertical"
                            android:hint="dd/mm/yyyy"
                            android:paddingHorizontal="16dp"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#475569"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="Available Time Slots"
                            android:textColor="#94A3B8" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="MORNING"
                            android:textColor="#64748B"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <GridLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:columnCount="2"
                            android:useDefaultMargins="true">

                            <Button
                                android:id="@+id/btnTime8AM"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:backgroundTint="#334155"
                                android:text="08:00 AM"
                                android:textColor="#E2E8F0" />

                            <Button
                                android:id="@+id/btnTime9AM"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:backgroundTint="#334155"
                                android:text="09:00 AM"
                                android:textColor="#E2E8F0" />

                            <Button
                                android:id="@+id/btnTime10AM"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:backgroundTint="#334155"
                                android:text="10:00 AM"
                                android:textColor="#E2E8F0" />

                            <Button
                                android:id="@+id/btnTime11AM"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:backgroundTint="#334155"
                                android:text="11:00 AM"
                                android:textColor="#E2E8F0" />
                        </GridLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="AFTERNOON"
                            android:textColor="#64748B"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <GridLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="24dp"
                            android:columnCount="2"
                            android:useDefaultMargins="true">

                            <Button
                                android:id="@+id/btnTime1PM"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:backgroundTint="#334155"
                                android:text="01:00 PM"
                                android:textColor="#E2E8F0" />

                            <Button
                                android:id="@+id/btnTime2PM"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:backgroundTint="#334155"
                                android:text="02:00 PM"
                                android:textColor="#E2E8F0" />

                            <Button
                                android:id="@+id/btnTime3PM"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:backgroundTint="#334155"
                                android:text="03:00 PM"
                                android:textColor="#E2E8F0" />

                            <Button
                                android:id="@+id/btnTime4PM"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:backgroundTint="#334155"
                                android:text="04:00 PM"
                                android:textColor="#E2E8F0" />
                        </GridLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Additional Notes (Optional)"
                            android:textColor="#94A3B8" />

                        <EditText
                            android:id="@+id/etAppointmentNotes"
                            android:layout_width="match_parent"
                            android:layout_height="100dp"
                            android:layout_marginBottom="16dp"
                            android:background="@drawable/input_style"
                            android:gravity="top|start"
                            android:hint="Any special requests or details?"
                            android:inputType="textMultiLine"
                            android:padding="16dp"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#475569" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="40dp"
                    app:cardBackgroundColor="#1E293B"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="Summary"
                            android:textColor="#94A3B8" />

                        <TextView
                            android:id="@+id/tvSummary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="24dp"
                            android:background="#0F172A"
                            android:padding="16dp"
                            android:text="Your scheduling summary will appear here..."
                            android:textColor="#64748B"
                            android:textSize="14sp" />

                        <Button
                            android:id="@+id/btnSubmitAppointment"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:backgroundTint="#3B82F6"
                            android:text="Book Appointment"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#1E293B"
        app:headerLayout="@layout/nav_header"
        app:itemIconTint="#94A3B8"
        app:itemTextColor="#E2E8F0"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>